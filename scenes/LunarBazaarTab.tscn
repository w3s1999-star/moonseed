alignment = 1

[node name="MealsLabel" type="Label" parent="ScrollContainer/RootVBox/PressSection/PressSectionVBox"]
layout_mode = 2
text = "Meals today: 0  |  Costs 100✨ per moonpearl"
theme_override_font_sizes/font_size = 12
