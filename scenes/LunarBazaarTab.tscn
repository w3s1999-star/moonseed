[gd_scene format=3 uid="uid://coinecave001"]

[ext_resource type="Script" path="res://scripts/LunarBazaarTab.gd" id="1_lunarbazaar"]

[node name="LunarBazaarTab" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_lunarbazaar")

[node name="ScrollContainer" type="ScrollContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="RootVBox" type="VBoxContainer" parent="ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 18
offset_top = 0.0
offset_left = 0.0

[node name="HeaderLabel" type="Label" parent="ScrollContainer/RootVBox"]
layout_mode = 2
text = "🌙 LUNAR BAZAAR"
theme_override_font_sizes/font_size = 22
alignment = 1

[node name="WalletRow" type="HBoxContainer" parent="ScrollContainer/RootVBox"]
layout_mode = 2
theme_override_constants/separation = 20

[node name="CoinHBox" type="HBoxContainer" parent="ScrollContainer/RootVBox/WalletRow"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="CoinLabel" type="Label" parent="ScrollContainer/RootVBox/WalletRow/CoinHBox"]
layout_mode = 2
text = ""
theme_override_font_sizes/font_size = 15

[node name="MoonpearlsHBox" type="HBoxContainer" parent="ScrollContainer/RootVBox/WalletRow"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="MoonpearlsLabel" type="Label" parent="ScrollContainer/RootVBox/WalletRow/MoonpearlsHBox"]
layout_mode = 2
