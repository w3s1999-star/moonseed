theme_override_font_sizes/font_size = 15

[node name="Separator1" type="HSeparator" parent="ScrollContainer/RootVBox"]
layout_mode = 2

[node name="PressSection" type="PanelContainer" parent="ScrollContainer/RootVBox"]
layout_mode = 2

[node name="PressSectionVBox" type="VBoxContainer" parent="ScrollContainer/RootVBox/PressSection"]
layout_mode = 2
